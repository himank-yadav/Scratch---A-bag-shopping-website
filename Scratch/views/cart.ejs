```ejs
<%- include('./partials/header') %>

<%
    let totalMRP = 0;
    let totalDiscount = 0;

    user.cart.forEach(function(product){
        totalMRP += product.price;
        totalDiscount += product.discount;
    });

    let platformFee = user.cart.length > 0 ? 20 : 0;
    let shippingFee = 0;

    let totalAmount = totalMRP - totalDiscount + platformFee + shippingFee;
%>

<div class="w-full min-h-screen px-20 py-16 flex gap-10">

    <!-- LEFT SECTION -->
    <div class="w-[25%] flex-wrap">

        <% if(user.cart.length === 0){ %>

            <div class="bg-zinc-900 rounded-lg p-10 text-center">
                <h2 class="text-3xl font-semibold text-white">
                    Your Cart is Empty
                </h2>

                <p class="text-zinc-400 mt-3">
                    Looks like you haven't added anything yet.
                </p>

                <a href="/shop"
                    class="inline-block mt-6 px-6 py-3 rounded bg-blue-600 text-white hover:bg-blue-700">
                    Continue Shopping
                </a>
            </div>

        <% } %>

        <% user.cart.forEach(function(product){ %>

        <div class="bg-zinc-900 rounded-lg overflow-hidden mb-8">

            <div class="w-full h-72 bg-zinc-200">

                <img
                    src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                    alt="<%= product.name %>"
                    class="w-full h-full object-contain"
                >

            </div>

            <div class="p-5">

                <div class="flex justify-between items-start">

                    <div>

                        <h2 class="text-2xl font-semibold text-white">
                            <%= product.name %>
                        </h2>

                        <p class="mt-2 text-zinc-400">
                            Discount :
                            <span class="text-green-500">
                                ₹ <%= product.discount %>
                            </span>
                        </p>

                    </div>

                    <h2 class="text-2xl font-bold text-white">
                        ₹ <%= product.price %>
                    </h2>

                </div>

                <a
                    href="/removefromcart/<%= product._id %>"
                    class="inline-block mt-5 bg-red-600 hover:bg-red-700 text-white px-5 py-2 rounded">

                    Remove

                </a>

            </div>

        </div>

        <% }) %>

    </div>


    <!-- RIGHT SECTION -->

    <div class="w-[45%]">

        <div class="bg-zinc-900 rounded-lg p-8">

            <h2 class="text-3xl font-semibold text-white">
                Price Details
            </h2>

            <div class="mt-8 space-y-5 text-lg">

                <div class="flex justify-between text-white">
                    <span>Total MRP</span>
                    <span>₹ <%= totalMRP %></span>
                </div>

                <div class="flex justify-between text-white">
                    <span>Total Discount</span>
                    <span class="text-green-500">
                        - ₹ <%= totalDiscount %>
                    </span>
                </div>

                <div class="flex justify-between text-white">
                    <span>Platform Fee</span>
                    <span>
                        ₹ <%= platformFee %>
                    </span>
                </div>

                <div class="flex justify-between text-white">
                    <span>Shipping Fee</span>
                    <span class="text-green-500">
                        FREE
                    </span>
                </div>

            </div>

            <hr class="border-zinc-700 my-8">

            <div class="flex justify-between items-center text-white">

                <h2 class="text-2xl font-semibold">
                    Total Amount
                </h2>

                <h2 class="text-3xl font-bold text-green-500">
                    ₹ <%= totalAmount %>
                </h2>

            </div>

            <% if(user.cart.length > 0){ %>

                <button
                    class="w-full mt-8 bg-green-600 hover:bg-green-700 text-white py-4 rounded-lg text-lg font-semibold">

                    Proceed to Checkout

                </button>

            <% } %>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>
```
